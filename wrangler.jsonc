{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "floral-leaf-4e44",
  "main": "./src/worker.js",
  "compatibility_date": "2026-04-12",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/prompts",
      "/prompts/*"
    ]
  }
}
